def manifest_json(palette: dict[str, Any], base_path: str) -> str:
    app_name = palette["appName"]
    slug = palette["slug"]
    manifest = {
        "name": app_name,
        "short_name": app_name,
        "id": f"{base_path}{slug}/",
        "start_url": f"{base_path}{slug}/",
        "scope": f"{base_path}{slug}/",
        "display": "standalone",
        "background_color": "#f7f2e8",
        "theme_color": "#f7f2e8",
        "description": f"ESKYNA Farben - {palette['name']}",
        "icons": [
            {"src": f"{base_path}icons/{slug}-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any maskable"},
            {"src": f"{base_path}icons/{slug}-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable"}
        ]
    }
    return json.dumps(manifest, ensure_ascii=False, indent=2) + "\n"


def service_worker_js(palettes: list[dict[str, Any]], base_path: str) -> str:
    assets = [
        base_path,
        base_path + "index.html",
        base_path + "styles.css",
        base_path + "palettes.js",
        base_path + "overview.js",
        base_path + "palette-app.js",
        base_path + "assets/sign_gold.png",
        base_path + "icons/icon-192.png",
        base_path + "icons/icon-512.png",
        base_path + "icons/apple-touch-icon.png",
    ]
    for p in palettes:
        slug = p["slug"]
        assets.append(base_path + slug + "/")
        assets.append(base_path + slug + "/index.html")
        assets.append(base_path + slug + "/manifest.webmanifest")
        assets.append(base_path + "icons/" + slug + ".png")
        assets.append(base_path + "icons/" + slug + "-192.png")
        assets.append(base_path + "icons/" + slug + "-512.png")
        assets.append(base_path + "icons/" + slug + "-apple-touch-icon.png")
    return (
        'const CACHE_NAME = "eskyna-farben-v1";\n'
        f'const FALLBACK_URL = "{base_path}";\n'
        'const APP_SHELL = '
        + json.dumps(assets, ensure_ascii=False, indent=2)
        + ';\n\n'
        + r'''
self.addEventListener('install', (event) => {
  event.waitUntil(
    caches.open(CACHE_NAME).then((cache) => cache.addAll(APP_SHELL)).catch(() => {})
  );
  self.skipWaiting();
});

self.addEventListener('activate', (event) => {
  event.waitUntil(
    caches.keys().then((keys) => Promise.all(keys.filter((key) => key !== CACHE_NAME).map((key) => caches.delete(key))))
  );
  self.clients.claim();
});

self.addEventListener('fetch', (event) => {
  if (event.request.method !== 'GET') return;
  event.respondWith(
    caches.match(event.request).then((cached) => {
      if (cached) return cached;
      return fetch(event.request).then((response) => {
        const copy = response.clone();
        caches.open(CACHE_NAME).then((cache) => cache.put(event.request, copy)).catch(() => {});
        return response;
      }).catch(() => {
        if (event.request.mode === 'navigate') return caches.match(FALLBACK_URL);
      });
    })
  );
});
'''.lstrip()
    )


def readme_md(base_path: str) -> str:
    return f'''# ESKYNA Farben PWAs

Dieses Verzeichnis wurde automatisch generiert.

Upload: Den kompletten Ordner `farbe` ins Webroot hochladen, sodass diese URL funktioniert:

- https://eskyna.com{base_path}

Beispiel-Kundinnenlink:

- https://eskyna.com{base_path}light_warm_soft/

Auf der Übersichtsseite stehen nur die 24 Farbkarten zur Auswahl. Jede Unterseite zeigt genau eine Farbkarte ohne Umschalten und ist durch ihr eigenes Manifest installierbar.

Alle wiederverwendeten Dateien liegen nur einmal zentral unter `{base_path}`:

- styles.css
- palettes.js
- overview.js
- palette-app.js
- sw.js
- assets/sign_gold.png
- icons/*

Jede Farbkarte hat ein eigenes App-Icon. Lege vor dem Generieren die PNG-Dateien unter `./icons/<slug>.png` ab, z. B. `./icons/light_warm_soft.png`. Der Generator erzeugt daraus automatisch die Manifest-Icons `192x192`, `512x512` und das iOS-Icon. Fehlt eine Datei, wird als Fallback das ESKYNA-Symbol verwendet.

Pro Farbkarte werden nur `index.html` und `manifest.webmanifest` generiert.

Hinweis: Kamera und PWA-Installation funktionieren auf Mobilgeräten nur zuverlässig mit HTTPS.
'''


def generate(output: Path, base_path: str, logo_path: str | None, palette_icons_dir: str | None, require_palette_icons: bool, make_zip: bool, zip_name: str | None) -> Path | None:
    palettes = load_palettes()
    clean_output(output)
    farbe_dir = output / base_path.strip("/")
    farbe_dir.mkdir(parents=True, exist_ok=True)

    missing_icons = create_icons(logo_bytes_from_args(logo_path), farbe_dir, palettes, palette_icons_dir)
    if require_palette_icons and missing_icons:
        raise FileNotFoundError("Fehlende Palette-Icons: " + ", ".join(missing_icons))

    write_text(farbe_dir / "palettes.js", palettes_js(palettes))
    write_text(farbe_dir / "styles.css", styles_css())
    write_text(farbe_dir / "overview.js", overview_js())
    write_text(farbe_dir / "palette-app.js", palette_app_js())
    write_text(farbe_dir / "index.html", overview_html(base_path))
    write_text(farbe_dir / "sw.js", service_worker_js(palettes, base_path))

    for palette in palettes:
        palette_dir = farbe_dir / palette["slug"]
        palette_dir.mkdir(parents=True, exist_ok=True)
        write_text(palette_dir / "index.html", palette_html(palette, base_path))
        write_text(palette_dir / "manifest.webmanifest", manifest_json(palette, base_path))

    url_map = [
        {
            "number": p["id"],
            "slug": p["slug"],
            "name": p["name"],
            "appName": p["appName"],
            "url": base_path + p["slug"] + "/",
            "icon": base_path + "icons/" + p["slug"] + "-512.png",
        }
        for p in palettes
    ]
    write_text(output / "palette-url-map.json", json.dumps(url_map, ensure_ascii=False, indent=2) + "\n")
    write_text(output / "README.md", readme_md(base_path))

    zip_path = None
    if make_zip:
        zip_path = Path(zip_name) if zip_name else output.with_suffix(".zip")
        if zip_path.exists():
            zip_path.unlink()
        with zipfile.ZipFile(zip_path, "w", zipfile.ZIP_DEFLATED) as zf:
            for file in output.rglob("*"):
                if file.is_file():
                    zf.write(file, file.relative_to(output.parent))

    return zip_path


def main() -> int:
    parser = argparse.ArgumentParser(description="Generiert die 24 ESKYNA Farben PWAs als statische /farbe/-Website.")
    parser.add_argument("--output", default="./dist", help="Zielordner. Standard: ./dist")
    parser.add_argument("--base-path", default="/farbe/", help="URL-Basispfad. Für eskyna.com: /farbe/")
    parser.add_argument("--logo", default=None, help="Optionaler Pfad zu sign_gold.png. Ohne Angabe wird das eingebettete Logo verwendet.")
    parser.add_argument("--palette-icons", default="./icons", help="Ordner mit App-Icons pro Palette, z. B. icons/light_warm_soft.png. Standard: ./icons")
    parser.add_argument("--require-palette-icons", action="store_true", help="Bricht ab, wenn nicht für alle 24 Paletten ein eigenes Icon vorhanden ist.")
    parser.add_argument("--zip", action="store_true", help="Erstellt zusätzlich eine ZIP-Datei des Zielordners.")
    parser.add_argument("--zip-name", default=None, help="Optionaler Name/Pfad der ZIP-Datei.")
    args = parser.parse_args()

    output = Path(args.output).resolve()
    base_path = normalize_base_path(args.base_path)

    try:
        zip_path = generate(output, base_path, args.logo, args.palette_icons, args.require_palette_icons, args.zip, args.zip_name)
    except Exception as exc:
        print(f"Fehler: {exc}", file=sys.stderr)
        return 1

    print(f"Fertig: {output}")
    print(f"Übersicht: {base_path}")
    print(f"Beispiel: {base_path}light_warm_soft/")
    if zip_path:
        print(f"ZIP: {zip_path.resolve()}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
