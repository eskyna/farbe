#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Generator für die ESKYNA Farben PWAs.

Erzeugt eine statische /farbe/-Struktur ohne Code-Duplikation:
- /farbe/                 Übersicht mit genau 24 Farbkarten
- /farbe/<palette_slug>/  eine installierbare PWA pro Farbkarte

Jede PWA nutzt dieselben gemeinsamen Dateien:
styles.css, palettes.js, overview.js, palette-app.js, sw.js, assets/sign_gold.png

Jede Farbkarte bekommt ihr eigenes App-Icon. Der Generator sucht standardmäßig
in ./icons nach Dateien wie icons/light_warm_soft.png. Fehlt eine Datei, wird
als Fallback sign_gold.png genutzt.

Pro Farbkarte werden nur index.html und manifest.webmanifest generiert.

Standard:
  ./bin/generate

Für eskyna.com:
  ./bin/generate --output ./dist --base-path /farbe/ --zip

Danach den Ordner ./dist/farbe in das Webroot hochladen, sodass
https://eskyna.com/farbe/ erreichbar ist.
"""

from __future__ import annotations

import argparse
import base64
import json
import shutil
import sys
import zipfile
from html import escape
from pathlib import Path
from typing import Any

