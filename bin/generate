  }
]'''


def read_repo_text(path: Path) -> str:
  if not path.exists() or not path.is_file():
    raise FileNotFoundError(f"Datei nicht gefunden: {path}")
  return path.read_text(encoding="utf-8")


def rewrite_base_path(content: str, base_path: str) -> str:
  return content.replace("/farbe/", base_path)


def render_template(path: Path, replacements: dict[str, str]) -> str:
  content = read_repo_text(path)
  for key, value in replacements.items():
    content = content.replace(key, value)
  return content


def write_text(path: Path, content: str) -> None:
  path.parent.mkdir(parents=True, exist_ok=True)
  path.write_text(content, encoding="utf-8")


def write_binary(path: Path, content: bytes) -> None:
  path.parent.mkdir(parents=True, exist_ok=True)
  path.write_bytes(content)


def clean_output(path: Path) -> None:
  if path.exists():
    shutil.rmtree(path)
  path.mkdir(parents=True, exist_ok=True)


def load_palettes() -> list[dict[str, Any]]:
  palettes = json.loads(PALETTES_JSON)
  if len(palettes) != EXPECTED_PALETTE_COUNT:
    raise RuntimeError(f"Erwartet {EXPECTED_PALETTE_COUNT} Paletten, gefunden: {len(palettes)}")
  for palette in palettes:
    grid = palette.get("grid")
    if len(grid) != 6 or any(len(row) != 4 for row in grid):
      raise RuntimeError(f"Palette {palette.get('slug')} hat kein 6x4 Raster")
    palette["appName"] = "ESKYNA Farbe"
  return palettes


def logo_bytes_from_args(logo_path: str | None) -> bytes:
  candidate = Path(logo_path) if logo_path else DEFAULT_LOGO_PATH
  if not candidate.exists() or not candidate.is_file():
    raise FileNotFoundError(f"Logo nicht gefunden: {candidate}")
  return candidate.read_bytes()


def find_palette_icon_file(slug: str, palette_icons_dir: str | None) -> Path | None:
  if not palette_icons_dir:
    return None
  root = Path(palette_icons_dir).expanduser()
  base_names = [slug, slug.replace("_", " ")]
  candidates = [
    root / f"{base_name}{suffix}"
    for base_name in base_names
    for suffix in (".png", ".jpg", ".jpeg", ".webp")
  ]
  for candidate in candidates:
    if candidate.exists() and candidate.is_file():
      return candidate
  return None


def make_icon_png(source_bytes: bytes, size: int, *, add_background: bool = True, margin_ratio: float = 0.12) -> bytes:
  try:
    from io import BytesIO

    from PIL import Image  # type: ignore

    source = Image.open(BytesIO(source_bytes)).convert("RGBA")
    if add_background:
      background = Image.new("RGBA", (size, size), (247, 242, 232, 255))
      mark = source.copy()
      margin = int(size * margin_ratio)
      max_side = max(1, size - 2 * margin)
      mark.thumbnail((max_side, max_side), Image.LANCZOS)
      x = (size - mark.width) // 2
      y = (size - mark.height) // 2
      background.alpha_composite(mark, (x, y))
      out_img = background.convert("RGB")
    else:
      source.thumbnail((size, size), Image.LANCZOS)
      canvas = Image.new("RGBA", (size, size), (247, 242, 232, 255))
      x = (size - source.width) // 2
      y = (size - source.height) // 2
      canvas.alpha_composite(source, (x, y))
      out_img = canvas.convert("RGB")

    out = BytesIO()
    out_img.save(out, format="PNG", optimize=True)
    return out.getvalue()
  except Exception:
    return source_bytes


def create_icons(logo_png: bytes, farbe_dir: Path, palettes: list[dict[str, Any]], palette_icons_dir: str | None) -> list[str]:
  _ = palette_icons_dir
  assets = farbe_dir / "assets"
  icons = farbe_dir / "icons"
  app_icon_png = APP_ICON_PATH.read_bytes() if APP_ICON_PATH.exists() else logo_png
  write_binary(assets / "sign_gold.png", logo_png)
  write_binary(assets / "app-icon.png", app_icon_png)

  for asset_name in ("splash-portrait.jpg", "splash-landscape.jpg", "app-background.jpg"):
    asset_path = ROOT_DIR / "assets" / asset_name
    if asset_path.exists() and asset_path.is_file():
      write_binary(assets / asset_name, asset_path.read_bytes())

  icon_192 = make_icon_png(app_icon_png, 192, add_background=False)
  icon_512 = make_icon_png(app_icon_png, 512, add_background=False)
  maskable_192 = make_icon_png(app_icon_png, 192, add_background=True, margin_ratio=0.18)
  maskable_512 = make_icon_png(app_icon_png, 512, add_background=True, margin_ratio=0.18)
  apple_icon = make_icon_png(app_icon_png, 180, add_background=False)
  apple_icon_120 = make_icon_png(app_icon_png, 120, add_background=False)
  apple_icon_152 = make_icon_png(app_icon_png, 152, add_background=False)
  apple_icon_167 = make_icon_png(app_icon_png, 167, add_background=False)
  apple_icon_180 = make_icon_png(app_icon_png, 180, add_background=False)

  write_binary(icons / "icon-192.png", icon_192)
  write_binary(icons / "icon-512.png", icon_512)
  write_binary(icons / "icon-maskable-192.png", maskable_192)
  write_binary(icons / "icon-maskable-512.png", maskable_512)
  write_binary(icons / "apple-touch-icon.png", apple_icon)
  write_binary(icons / "apple-touch-icon-120.png", apple_icon_120)
  write_binary(icons / "apple-touch-icon-152.png", apple_icon_152)
  write_binary(icons / "apple-touch-icon-167.png", apple_icon_167)
  write_binary(icons / "apple-touch-icon-180.png", apple_icon_180)

  # Backwards compatibility for Android/Chrome installations that still have
  # an older cached palette manifest. Earlier builds referenced per-palette icon
  # URLs like /farbe/icons/hell_warm-512.png. Keeping these files online
  # prevents installability from breaking while Chrome refreshes its manifest
  # and icon cache. The actual current manifest uses the central icon files.
  legacy_icon_slugs = sorted({str(palette["slug"]) for palette in palettes} | set(LEGACY_PALETTE_REDIRECTS.keys()))
  for slug in legacy_icon_slugs:
    write_binary(icons / f"{slug}.png", icon_512)
    write_binary(icons / f"{slug}-192.png", icon_192)
    write_binary(icons / f"{slug}-512.png", icon_512)
    write_binary(icons / f"{slug}-apple-touch-icon.png", apple_icon)

  return []


def verify_generated_icons(farbe_dir: Path, palettes: list[dict[str, Any]]) -> None:
  required_files = [
    farbe_dir / "icons" / "icon-192.png",
    farbe_dir / "icons" / "icon-512.png",
    farbe_dir / "icons" / "icon-maskable-192.png",
    farbe_dir / "icons" / "icon-maskable-512.png",
    farbe_dir / "icons" / "apple-touch-icon.png",
    farbe_dir / "icons" / "apple-touch-icon-120.png",
    farbe_dir / "icons" / "apple-touch-icon-152.png",
    farbe_dir / "icons" / "apple-touch-icon-167.png",
    farbe_dir / "icons" / "apple-touch-icon-180.png",
    farbe_dir / "assets" / "sign_gold.png",
    farbe_dir / "assets" / "app-icon.png",
    farbe_dir / "assets" / "splash-portrait.jpg",
    farbe_dir / "assets" / "splash-landscape.jpg",
    farbe_dir / "assets" / "app-background.jpg",
  ]

  missing_files = [str(path.relative_to(farbe_dir)) for path in required_files if not path.exists()]
  if missing_files:
    raise FileNotFoundError("Fehlende generierte Icons: " + ", ".join(missing_files))


def palettes_js(palettes: list[dict[str, Any]]) -> str:
  return (
    "// Automatisch generiert. Alle Palettenwerte liegen zentral hier.\n"
    "window.ESKYNA_PALETTES = "
    + json.dumps(palettes, ensure_ascii=False, indent=2)
    + ";\n"
  )


def styles_css() -> str:
  return read_repo_text(ROOT_DIR / "styles.css")


def overview_js() -> str:
  return read_repo_text(ROOT_DIR / "overview.js")


def i18n_js() -> str:
  return read_repo_text(ROOT_DIR / "i18n.js")


def palette_app_js(build_version: str) -> str:
  return read_repo_text(ROOT_DIR / "palette-app.js").replace("__ESKYNA_APP_VERSION__", build_version)


def overview_html(base_path: str, build_version: str) -> str:
  return rewrite_base_path(read_repo_text(ROOT_DIR / "index.html"), base_path).replace("__ESKYNA_APP_VERSION__", build_version)


def palette_html(palette: dict[str, Any], base_path: str, build_version: str) -> str:
  name = escape(palette["name"])
  app_name = escape(palette["appName"])
  slug = escape(palette["slug"])
  return render_template(
    TEMPLATES_DIR / "palette.html",
    {
      "__APP_NAME__": app_name,
      "__PALETTE_NAME__": name,
      "__PALETTE_SLUG__": slug,
      "__BASE_PATH__": base_path,
      "__TELEGRAM_BOT_URL__": DEFAULT_TELEGRAM_BOT_URL,
      "__ESKYNA_APP_VERSION__": build_version,
    },
  )


def app_manifest_icons(base_path: str) -> list[dict[str, str]]:
  return [
    {"src": f"{base_path}icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any"},
    {"src": f"{base_path}icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any"},
    {"src": f"{base_path}icons/icon-maskable-192.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable"},
    {"src": f"{base_path}icons/icon-maskable-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable"},
  ]


def overview_manifest_json(base_path: str) -> str:
  manifest = {
    "name": "ESKYNA Farbe",
    "short_name": "ESKYNA Farbe",
    "id": base_path,
    "start_url": base_path,
    "scope": base_path,
    "display": "standalone",
    "background_color": "#f7f2e8",
    "theme_color": "#f7f2e8",
    "description": "ESKYNA Farbe - Übersicht und installierbare Farbkarten",
    "icons": app_manifest_icons(base_path)
  }
  return json.dumps(manifest, ensure_ascii=False, indent=2) + "\n"


def legacy_redirect_html(legacy_slug: str, target_slug: str, base_path: str, build_version: str) -> str:
    target_path = base_path + (target_slug + "/" if target_slug else "")
    title = "ESKYNA Farbe"
    message = "Diese Farbkarte wurde umbenannt. Du wirst weitergeleitet."
    return f"""<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex" />
  <meta http-equiv="refresh" content="0; url={escape(target_path)}" />
  <title>{escape(title)}</title>
  <script>
    window.__ESKYNA_LEGACY_REDIRECT__ = {{ legacySlug: {json.dumps(legacy_slug)}, targetPath: {json.dumps(target_path)}, version: {json.dumps(build_version)} }};
    const target = window.__ESKYNA_LEGACY_REDIRECT__.targetPath + window.location.search + window.location.hash;
    window.location.replace(target);
  </script>
</head>
<body>
  <p>{escape(message)} <a href="{escape(target_path)}">Zur Farbkarte</a></p>
</body>
</html>
"""


def manifest_json(palette: dict[str, Any], base_path: str) -> str:
    app_name = palette["appName"]
    slug = palette["slug"]
    manifest = {
        "name": app_name,
        "short_name": app_name,
        "id": f"{base_path}{slug}/",
        "start_url": f"{base_path}{slug}/",
        "scope": f"{base_path}{slug}/",
        "display": "standalone",
        "background_color": "#f7f2e8",
        "theme_color": "#f7f2e8",
        "description": f"ESKYNA Farben - {palette['name']}",
        "icons": app_manifest_icons(base_path)
    }
    return json.dumps(manifest, ensure_ascii=False, indent=2) + "\n"


def palette_shell_urls(palettes: list[dict[str, Any]], base_path: str) -> list[str]:
    urls: list[str] = []
    for palette in palettes:
        palette_base = f"{base_path}{palette['slug']}/"
        urls.extend([palette_base, palette_base + "index.html", palette_base + "manifest.webmanifest"])

    for legacy_slug in LEGACY_PALETTE_REDIRECTS:
        legacy_base = f"{base_path}{legacy_slug}/"
        urls.extend([legacy_base, legacy_base + "index.html"])
    return urls


def service_worker_js(palettes: list[dict[str, Any]], base_path: str, build_version: str) -> str:
    palette_shell = json.dumps(palette_shell_urls(palettes, base_path), ensure_ascii=False, indent=2)
    content = rewrite_base_path(read_repo_text(ROOT_DIR / "sw.js"), base_path)
    return content.replace("__ESKYNA_PALETTE_SHELL__", palette_shell).replace("__ESKYNA_APP_VERSION__", build_version)


def version_json(build_version: str) -> str:
    payload = {
        "version": build_version,
        "generatedAt": datetime.now(timezone.utc).isoformat()
    }
    return json.dumps(payload, ensure_ascii=False, indent=2) + "\n"


def readme_md(base_path: str) -> str:
  return render_template(
    TEMPLATES_DIR / "dist-README.md",
    {
      "__BASE_PATH__": base_path,
    },
  )


def generate(output: Path) -> None:
  palettes = load_palettes()
  build_version = datetime.now(timezone.utc).strftime("%Y%m%d%H%M%S")
  clean_output(output)
  farbe_dir = output
  farbe_dir.mkdir(parents=True, exist_ok=True)

  missing_icons = create_icons(logo_bytes_from_args(None), farbe_dir, palettes, str(DEFAULT_PALETTE_ICONS_DIR))
  if missing_icons:
    raise FileNotFoundError("Fehlende Palette-Icons: " + ", ".join(missing_icons))
  verify_generated_icons(farbe_dir, palettes)

  write_text(farbe_dir / "palettes.js", palettes_js(palettes))
  write_text(farbe_dir / "styles.css", styles_css())
  write_text(farbe_dir / "overview.js", overview_js())
  write_text(farbe_dir / "i18n.js", i18n_js())
  write_text(farbe_dir / "palette-app.js", palette_app_js(build_version))
  write_text(farbe_dir / "index.html", overview_html(DEFAULT_BASE_PATH, build_version))
  write_text(farbe_dir / "manifest.webmanifest", overview_manifest_json(DEFAULT_BASE_PATH))
  write_text(farbe_dir / "version.json", version_json(build_version))
  write_text(farbe_dir / "sw.js", service_worker_js(palettes, DEFAULT_BASE_PATH, build_version))

  for palette in palettes:
    palette_dir = farbe_dir / palette["slug"]
    palette_dir.mkdir(parents=True, exist_ok=True)
    write_text(palette_dir / "index.html", palette_html(palette, DEFAULT_BASE_PATH, build_version))
    write_text(palette_dir / "manifest.webmanifest", manifest_json(palette, DEFAULT_BASE_PATH))

  generated_slugs = {str(palette["slug"]) for palette in palettes}
  for legacy_slug, target_slug in LEGACY_PALETTE_REDIRECTS.items():
    if legacy_slug in generated_slugs:
      continue
    legacy_dir = farbe_dir / legacy_slug
    legacy_dir.mkdir(parents=True, exist_ok=True)
    write_text(legacy_dir / "index.html", legacy_redirect_html(legacy_slug, target_slug, DEFAULT_BASE_PATH, build_version))

  url_map = [
    {
      "number": p["id"],
      "slug": p["slug"],
      "name": p["name"],
      "appName": p["appName"],
      "url": DEFAULT_BASE_PATH + p["slug"] + "/",
      "icon": DEFAULT_BASE_PATH + "icons/icon-512.png",
    }
    for p in palettes
  ]
  write_text(output / "palette-url-map.json", json.dumps(url_map, ensure_ascii=False, indent=2) + "\n")
  write_text(output / "README.md", readme_md(DEFAULT_BASE_PATH))


def main() -> int:
  parser = argparse.ArgumentParser(description="Generiert die 12 ESKYNA Farben PWAs als statische GitHub-Pages-Website.")
  parser.add_argument("--output", default="./dist", help="Zielordner. Standard: ./dist")
  args = parser.parse_args()

  output = Path(args.output).resolve()

  try:
    generate(output)
  except Exception as exc:
    print(f"Fehler: {exc}", file=sys.stderr)
    return 1

  print(f"Fertig: {output}")
  print(f"Übersicht: {DEFAULT_BASE_PATH}")
  print(f"Beispiel: {DEFAULT_BASE_PATH}hell_warm/")
  return 0


if __name__ == "__main__":
    raise SystemExit(main())
