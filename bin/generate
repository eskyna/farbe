#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Generator für die ESKYNA Farben PWAs.

Erzeugt eine statische Website ohne Code-Duplikation:
- /                       Übersicht mit genau 24 Farbkarten
- /<palette_slug>/        eine installierbare PWA pro Farbkarte

Jede PWA nutzt dieselben gemeinsamen Dateien:
styles.css, palettes.js, overview.js, palette-app.js, sw.js, assets/sign_gold.png

Jede Farbkarte bekommt ihr eigenes App-Icon. Der Generator sucht standardmäßig
in ./icons nach Dateien wie icons/light_warm_soft.png. Fehlt eine Datei, wird
als Fallback sign_gold.png genutzt.

Pro Farbkarte werden nur index.html und manifest.webmanifest generiert.

Standard:
  ./bin/generate

Für eskyna.com:
  ./bin/generate --output ./dist

Danach den Inhalt von ./dist in das GitHub-Pages-Artefakt oder Webroot hochladen, sodass
https://eskyna.com/farbe/ erreichbar ist.
"""

from __future__ import annotations

import argparse
import json
import shutil
import sys
from html import escape
from pathlib import Path
from typing import Any

ROOT_DIR = Path(__file__).resolve().parent.parent
TEMPLATES_DIR = ROOT_DIR / "templates"
DEFAULT_LOGO_PATH = ROOT_DIR / "assets" / "sign_gold.png"
DEFAULT_BASE_PATH = "/farbe/"
DEFAULT_PALETTE_ICONS_DIR = ROOT_DIR / "icons"

