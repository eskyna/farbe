def read_repo_text(path: Path) -> str:
  if not path.exists() or not path.is_file():
    raise FileNotFoundError(f"Datei nicht gefunden: {path}")
  return path.read_text(encoding="utf-8")


def rewrite_base_path(content: str, base_path: str) -> str:
  return content.replace("/farbe/", base_path)


def render_template(path: Path, replacements: dict[str, str]) -> str:
  content = read_repo_text(path)
  for key, value in replacements.items():
    content = content.replace(key, value)
  return content


def write_text(path: Path, content: str) -> None:
  path.parent.mkdir(parents=True, exist_ok=True)
  path.write_text(content, encoding="utf-8")


def write_binary(path: Path, content: bytes) -> None:
  path.parent.mkdir(parents=True, exist_ok=True)
  path.write_bytes(content)


def clean_output(path: Path) -> None:
  if path.exists():
    shutil.rmtree(path)
  path.mkdir(parents=True, exist_ok=True)


def load_palettes() -> list[dict[str, Any]]:
  palettes = json.loads(PALETTES_JSON)
  if len(palettes) != 24:
    raise RuntimeError(f"Erwartet 24 Paletten, gefunden: {len(palettes)}")
  for palette in palettes:
    grid = palette.get("grid")
    if len(grid) != 6 or any(len(row) != 4 for row in grid):
      raise RuntimeError(f"Palette {palette.get('slug')} hat kein 6x4 Raster")
    palette["appName"] = "ESKYNA - " + palette["name"]
  return palettes


def logo_bytes_from_args(logo_path: str | None) -> bytes:
  candidate = Path(logo_path) if logo_path else DEFAULT_LOGO_PATH
  if not candidate.exists() or not candidate.is_file():
    raise FileNotFoundError(f"Logo nicht gefunden: {candidate}")
  return candidate.read_bytes()


def find_palette_icon_file(slug: str, palette_icons_dir: str | None) -> Path | None:
  if not palette_icons_dir:
    return None
  root = Path(palette_icons_dir).expanduser()
  base_names = [slug, slug.replace("_", " ")]
  candidates = [
    root / f"{base_name}{suffix}"
    for base_name in base_names
    for suffix in (".png", ".jpg", ".jpeg", ".webp")
  ]
  for candidate in candidates:
    if candidate.exists() and candidate.is_file():
      return candidate
  return None


def make_icon_png(source_bytes: bytes, size: int, *, add_background: bool = True) -> bytes:
  try:
    from io import BytesIO

    from PIL import Image  # type: ignore

    source = Image.open(BytesIO(source_bytes)).convert("RGBA")
    if add_background:
      background = Image.new("RGBA", (size, size), (247, 242, 232, 255))
      mark = source.copy()
      margin = int(size * 0.12)
      mark.thumbnail((size - 2 * margin, size - 2 * margin), Image.LANCZOS)
      x = (size - mark.width) // 2
      y = (size - mark.height) // 2
      background.alpha_composite(mark, (x, y))
      out_img = background.convert("RGB")
    else:
      source.thumbnail((size, size), Image.LANCZOS)
      canvas = Image.new("RGBA", (size, size), (0, 0, 0, 0))
      x = (size - source.width) // 2
      y = (size - source.height) // 2
      canvas.alpha_composite(source, (x, y))
      out_img = canvas

    out = BytesIO()
    out_img.save(out, format="PNG", optimize=True)
    return out.getvalue()
  except Exception:
    return source_bytes


def create_icons(logo_png: bytes, farbe_dir: Path, palettes: list[dict[str, Any]], palette_icons_dir: str | None) -> list[str]:
  assets = farbe_dir / "assets"
  icons = farbe_dir / "icons"
  write_binary(assets / "sign_gold.png", logo_png)

  write_binary(icons / "icon-192.png", make_icon_png(logo_png, 192))
  write_binary(icons / "icon-512.png", make_icon_png(logo_png, 512))
  write_binary(icons / "apple-touch-icon.png", make_icon_png(logo_png, 180))

  missing: list[str] = []
  for palette in palettes:
    slug = palette["slug"]
    icon_file = find_palette_icon_file(slug, palette_icons_dir)
    has_custom_icon = icon_file is not None
    if has_custom_icon:
      source_bytes = icon_file.read_bytes()
    else:
      source_bytes = logo_png
      missing.append(slug)

    write_binary(icons / f"{slug}.png", source_bytes)

    add_background = not has_custom_icon
    write_binary(icons / f"{slug}-192.png", make_icon_png(source_bytes, 192, add_background=add_background))
    write_binary(icons / f"{slug}-512.png", make_icon_png(source_bytes, 512, add_background=add_background))
    write_binary(icons / f"{slug}-apple-touch-icon.png", make_icon_png(source_bytes, 180, add_background=add_background))

  return missing


def verify_generated_icons(farbe_dir: Path, palettes: list[dict[str, Any]]) -> None:
  required_files = [
    farbe_dir / "icons" / "icon-192.png",
    farbe_dir / "icons" / "icon-512.png",
    farbe_dir / "icons" / "apple-touch-icon.png",
    farbe_dir / "assets" / "sign_gold.png",
  ]

  for palette in palettes:
    slug = palette["slug"]
    required_files.extend([
      farbe_dir / "icons" / f"{slug}.png",
      farbe_dir / "icons" / f"{slug}-192.png",
      farbe_dir / "icons" / f"{slug}-512.png",
      farbe_dir / "icons" / f"{slug}-apple-touch-icon.png",
    ])

  missing_files = [str(path.relative_to(farbe_dir)) for path in required_files if not path.exists()]
  if missing_files:
    raise FileNotFoundError("Fehlende generierte Icons: " + ", ".join(missing_files))


def palettes_js(palettes: list[dict[str, Any]]) -> str:
  return (
    "// Automatisch generiert. Alle Palettenwerte liegen zentral hier.\n"
    "window.ESKYNA_PALETTES = "
    + json.dumps(palettes, ensure_ascii=False, indent=2)
    + ";\n"
  )


def styles_css() -> str:
  return read_repo_text(ROOT_DIR / "styles.css")


def overview_js() -> str:
  return read_repo_text(ROOT_DIR / "overview.js")


def palette_app_js() -> str:
  return read_repo_text(ROOT_DIR / "palette-app.js")


def overview_html(base_path: str) -> str:
  return rewrite_base_path(read_repo_text(ROOT_DIR / "index.html"), base_path)


def palette_html(palette: dict[str, Any], base_path: str) -> str:
  name = escape(palette["name"])
  app_name = escape(palette["appName"])
  slug = escape(palette["slug"])
  return render_template(
    TEMPLATES_DIR / "palette.html",
    {
      "__APP_NAME__": app_name,
      "__PALETTE_NAME__": name,
      "__PALETTE_SLUG__": slug,
      "__BASE_PATH__": base_path,
    },
  )


def overview_manifest_json(base_path: str) -> str:
  manifest = {
    "name": "ESKYNA Farben",
    "short_name": "ESKYNA Farben",
    "id": base_path,
    "start_url": base_path,
    "scope": base_path,
    "display": "standalone",
    "background_color": "#f7f2e8",
    "theme_color": "#f7f2e8",
    "description": "ESKYNA Farben - Übersicht und installierbare Farbkarten",
    "icons": [
      {"src": f"{base_path}icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any maskable"},
      {"src": f"{base_path}icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable"}
    ]
  }
  return json.dumps(manifest, ensure_ascii=False, indent=2) + "\n"


def manifest_json(palette: dict[str, Any], base_path: str) -> str:
    app_name = palette["appName"]
    slug = palette["slug"]
    manifest = {
        "name": app_name,
        "short_name": app_name,
        "id": f"{base_path}{slug}/",
        "start_url": f"{base_path}{slug}/",
        "scope": f"{base_path}{slug}/",
        "display": "standalone",
        "background_color": "#f7f2e8",
        "theme_color": "#f7f2e8",
        "description": f"ESKYNA Farben - {palette['name']}",
        "icons": [
            {"src": f"{base_path}icons/{slug}-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any maskable"},
            {"src": f"{base_path}icons/{slug}-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable"}
        ]
    }
    return json.dumps(manifest, ensure_ascii=False, indent=2) + "\n"


def service_worker_js(palettes: list[dict[str, Any]], base_path: str) -> str:
    _ = palettes
    return rewrite_base_path(read_repo_text(ROOT_DIR / "sw.js"), base_path)


def readme_md(base_path: str) -> str:
  return render_template(
    TEMPLATES_DIR / "dist-README.md",
    {
      "__BASE_PATH__": base_path,
    },
  )


def generate(output: Path) -> None:
  palettes = load_palettes()
  clean_output(output)
  farbe_dir = output
  farbe_dir.mkdir(parents=True, exist_ok=True)

  missing_icons = create_icons(logo_bytes_from_args(None), farbe_dir, palettes, str(DEFAULT_PALETTE_ICONS_DIR))
  if missing_icons:
    raise FileNotFoundError("Fehlende Palette-Icons: " + ", ".join(missing_icons))
  verify_generated_icons(farbe_dir, palettes)

  write_text(farbe_dir / "palettes.js", palettes_js(palettes))
  write_text(farbe_dir / "styles.css", styles_css())
  write_text(farbe_dir / "overview.js", overview_js())
  write_text(farbe_dir / "palette-app.js", palette_app_js())
  write_text(farbe_dir / "index.html", overview_html(DEFAULT_BASE_PATH))
  write_text(farbe_dir / "manifest.webmanifest", overview_manifest_json(DEFAULT_BASE_PATH))
  write_text(farbe_dir / "sw.js", service_worker_js(palettes, DEFAULT_BASE_PATH))

  for palette in palettes:
    palette_dir = farbe_dir / palette["slug"]
    palette_dir.mkdir(parents=True, exist_ok=True)
    write_text(palette_dir / "index.html", palette_html(palette, DEFAULT_BASE_PATH))
    write_text(palette_dir / "manifest.webmanifest", manifest_json(palette, DEFAULT_BASE_PATH))

  url_map = [
    {
      "number": p["id"],
      "slug": p["slug"],
      "name": p["name"],
      "appName": p["appName"],
      "url": DEFAULT_BASE_PATH + p["slug"] + "/",
      "icon": DEFAULT_BASE_PATH + "icons/" + p["slug"] + "-512.png",
    }
    for p in palettes
  ]
  write_text(output / "palette-url-map.json", json.dumps(url_map, ensure_ascii=False, indent=2) + "\n")
  write_text(output / "README.md", readme_md(DEFAULT_BASE_PATH))


def main() -> int:
  parser = argparse.ArgumentParser(description="Generiert die 24 ESKYNA Farben PWAs als statische GitHub-Pages-Website.")
  parser.add_argument("--output", default="./dist", help="Zielordner. Standard: ./dist")
  args = parser.parse_args()

  output = Path(args.output).resolve()

  try:
    generate(output)
  except Exception as exc:
    print(f"Fehler: {exc}", file=sys.stderr)
    return 1

  print(f"Fertig: {output}")
  print(f"Übersicht: {DEFAULT_BASE_PATH}")
  print(f"Beispiel: {DEFAULT_BASE_PATH}light_warm_soft/")
  return 0


if __name__ == "__main__":
    raise SystemExit(main())
