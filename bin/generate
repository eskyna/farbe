#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Generator für die ESKYNA Farben PWAs.

Erzeugt eine statische Website ohne Code-Duplikation:
- /                       Übersicht mit genau 12 Farbkarten
- /<palette_slug>/        eine installierbare PWA pro Farbkarte

Jede PWA nutzt dieselben gemeinsamen Dateien:
styles.css, palettes.js, overview.js, palette-app.js, sw.js, assets/sign_gold.png, assets/app-icon.png, assets/app-background.jpg

Alle installierbaren Farbkarten verwenden das zentrale ESKYNA-Farbe-App-Icon
aus assets/app-icon.png. Die alten Quell-Icons unter ./icons bleiben als
Referenzmaterial erhalten, sind aber nicht mehr die Installationsicons.

Pro Farbkarte werden nur index.html und manifest.webmanifest generiert.

Standard:
  ./bin/generate

Für eskyna.com:
  ./bin/generate --output ./dist

Danach den Inhalt von ./dist in das GitHub-Pages-Artefakt oder Webroot hochladen, sodass
https://eskyna.com/farbe/ erreichbar ist.
"""

from __future__ import annotations

import argparse
import json
import shutil
from datetime import datetime, timezone
import sys
from html import escape
from pathlib import Path
from typing import Any

